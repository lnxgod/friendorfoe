# Friend or Foe Backend — Environment Variables
# Copy to .env and fill in values.

# App
DEBUG=false

# OpenSky Network (optional — anonymous access has lower rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=10

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://friendorfoe:friendorfoe@localhost:5432/friendorfoe
